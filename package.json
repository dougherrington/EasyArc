{
  "name": "easyarc",
  "version": "0.2.6-alpha",
  "description": "The easiest way to play your retro game collection",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.dougherrington.easyarc",
    "productName": "EasyArc",
    "mac": {
      "category": "public.app-category.games",
      "target": "dmg"
    },
    "dmg": {
      "title": "EasyArc Alpha 2.4",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "crc32": "^0.2.2",
    "yauzl": "^3.3.0"
  }
}
